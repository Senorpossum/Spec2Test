{
    "name": "spec2test",
    "version": "1.0.0",
    "description": "Automated test suite generation from user stories and specification documents",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "spec2test": "./dist/cli/index.js"
    },
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/cli/index.js",
        "dev": "tsx src/cli/index.ts",
        "generate": "node dist/cli/index.js generate",
        "test": "echo \"No tests configured yet\""
    },
    "keywords": [
        "test-generation",
        "user-stories",
        "testing",
        "qa",
        "jest",
        "playwright",
        "cypress",
        "api-testing",
        "automated-testing"
    ],
    "author": "Senorpossum <https://github.com/Senorpossum>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Senorpossum/spec2test"
    },
    "bugs": {
        "url": "https://github.com/Senorpossum/spec2test/issues"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "commander": "^11.1.0",
        "figlet": "^1.7.0",
        "ora": "^8.0.1"
    },
    "devDependencies": {
        "@types/figlet": "^1.5.6",
        "@types/node": "^20.10.0",
        "typescript": "^5.3.0"
    }
}